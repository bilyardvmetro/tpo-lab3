@startuml
skinparam dpi 300
left to right direction
skinparam actorStyle awesome

actor "Гость сайта" as Guest
actor "Зарегистрированный\nпользователь" as User

rectangle "Tumblr.com" {
  usecase "Открытие главной\nстраницы" as UC1
  usecase "Переход к форме\nвхода / регистрации" as UC2
  usecase "Авторизация" as UC3
  usecase "Поиск контента" as UC4
  usecase "Просмотр страницы\nблога" as UC5
  usecase "Просмотр отдельного\nпоста" as UC6
}

Guest --> UC1
Guest --> UC2

User --> UC3
User --> UC4
User --> UC5
User --> UC6

UC4 .> UC3 : <<include>>
UC5 .> UC3 : <<include>>
UC6 .> UC3 : <<include>>
@enduml